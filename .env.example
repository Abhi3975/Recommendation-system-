# ==============================================================================
# Recommendation System LLM Re-ranking Configuration Template
# Copy this file to '.env' to configure your local or deployment environment:
#   $ cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Dataset Configuration
# ------------------------------------------------------------------------------
# The MovieLens dataset variant to load.
# Available options:
#   - 'synthetic' : Lightweight, zero external files required, extremely fast.
#   - 'ml-100k'   : MovieLens 100K (default, auto-downloads on startup, ~100k ratings).
#   - 'ml-1m'     : MovieLens 1M (~1M ratings, requires manual download or pre-existing files).
#   - 'ml-20m'    : MovieLens 20M (~20M ratings, memory intensive).
DATASET_VARIANT=ml-100k

# Number of users to sample from the dataset.
# Helps reduce memory usage (RAM) on constrained environments (e.g., Render free tier with 512 MB).
#   - Set to an integer (e.g., 150) to sample that exact number of users.
#   - Set to 'all', 'none', or '0' to load the full dataset without sampling.
SAMPLE_USERS=150


# ------------------------------------------------------------------------------
# 2. Model Training Configuration
# ------------------------------------------------------------------------------
# Number of epochs to train the Stage 1 Two-Tower neural retriever.
TWO_TOWER_EPOCHS=5

# Number of epochs to train the Stage 2 Neural MLP re-ranker.
RERANKER_EPOCHS=2


# ------------------------------------------------------------------------------
# 3. Memory & Performance Optimization
# ------------------------------------------------------------------------------
# Set to '1', 'true', or 'yes' to skip loading Sentence-Transformers (SBERT).
# When enabled, the re-ranker uses keyword-based fallback for context scoring,
# which reduces RAM usage significantly (saving ~200MB+ RAM) and prevents OOM crashes.
RERANKER_USE_KEYWORDS_ONLY=


# ------------------------------------------------------------------------------
# 4. Web Server Configuration
# ------------------------------------------------------------------------------
# The port number on which the FastAPI application will run.
PORT=8000
